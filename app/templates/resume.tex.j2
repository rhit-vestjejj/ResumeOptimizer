\documentclass[10pt,letterpaper]{article}
\usepackage[margin=0.64in]{geometry}
\usepackage[T1]{fontenc}
\usepackage[utf8]{inputenc}
\usepackage{enumitem}
\usepackage{lmodern}
\usepackage{titlesec}
\usepackage{microtype}
\pagestyle{empty}
\setlength{\parindent}{0pt}
\setlength{\parskip}{0.8pt}
\setlist[itemize]{leftmargin=1.0em, itemsep=0.6pt, topsep=0.8pt, parsep=0pt, partopsep=0pt}
\titlespacing*{\section}{0pt}{3.5pt}{1.8pt}
\titleformat{\section}{\bfseries\normalsize}{}{0em}{}[\vspace{-2pt}\hrule\vspace{-2pt}]

\begin{document}
\small
\raggedright

{\LARGE \textbf{ {{- resume.identity.name | latex_escape -}} }}\\
\texttt{ {{- resume.identity.email | latex_escape -}} }
\;|\; {{- resume.identity.phone | latex_escape -}}
\;|\; {{- resume.identity.location | latex_escape -}}
{% for link in resume.identity.links %}
\;|\; {{- link | latex_escape -}}
{% endfor %}

{% if resume.summary %}
\section*{Summary}
{{- resume.summary | latex_escape -}}
{% endif %}

{% if resume.education %}
\section*{Education}
{% for edu in resume.education %}
{% set edu_start = (edu.dates.start or '') %}
{% set edu_end = (edu.dates.end or '') %}
{% set edu_has_dates = edu_start or edu_end %}
\textbf{ {{- edu.school | latex_escape -}} }{% if edu_has_dates %} \hfill {{ edu_start | latex_escape -}}{% if edu_start and edu_end %} -- {% endif %}{{ edu_end | latex_escape -}}{% endif %}\\
{% if edu.degree or edu.major or edu.minors or edu.gpa %}
{{- edu.degree | latex_escape -}}{% if edu.major %} in {{ edu.major | latex_escape -}}{% endif %}{% if edu.minors %}; Minors: {{ edu.minors | join(', ') | latex_escape -}}{% endif %}{% if edu.gpa %}; GPA: {{ edu.gpa | latex_escape -}}{% endif %}\\
{% endif %}
{% if edu.coursework %}
\textit{Coursework}: {{ edu.coursework | join(', ') | latex_escape -}}\\
{% endif %}
{% endfor %}
{% endif %}

{% if resume.experience %}
\section*{Experience}
{% for exp in resume.experience %}
{% set exp_start = (exp.dates.start or '') %}
{% set exp_end = (exp.dates.end or '') %}
{% set exp_has_dates = exp_start or exp_end %}
{% set exp_company = (exp.company or '') %}
{% set exp_title = (exp.title or '') %}
{% set exp_heading = exp_company if exp_company else exp_title %}
\textbf{ {{- exp_heading | latex_escape -}} }{% if exp_has_dates %} \hfill {{ exp_start | latex_escape -}}{% if exp_start and exp_end %} -- {% endif %}{{ exp_end | latex_escape -}}{% endif %}\\
{% if exp_title and exp_title != exp_heading %}{{- exp_title | latex_escape -}}{% if exp.location %}, {{ exp.location | latex_escape -}}{% endif %}\\{% endif %}
\begin{itemize}
{% for bullet in exp.bullets %}
\item {{ bullet | latex_escape }}
{% endfor %}
\end{itemize}
{% endfor %}
{% endif %}

{% if resume.skills and resume.skills.categories %}
\section*{Skills}
{% for category, entries in resume.skills.categories.items() %}
{% set category_normalized = (category or '') | lower %}
{% set is_generic = category_normalized in ['skills', 'core skills', 'technical skills', 'technologies', 'tools'] %}
{% if is_generic %}
{{ entries | join(', ') | latex_escape -}}\\
{% else %}
\textbf{ {{- category | latex_escape -}} }: {{ entries | join(', ') | latex_escape -}}\\
{% endif %}
{% endfor %}
{% endif %}

{% set ns = namespace(main_count=0, minor_count=0) %}
{% for project in resume.projects %}
{% if (project.section or 'projects') == 'minor_projects' %}
{% set ns.minor_count = ns.minor_count + 1 %}
{% else %}
{% set ns.main_count = ns.main_count + 1 %}
{% endif %}
{% endfor %}

{% if ns.main_count > 0 %}
\section*{Projects}
{% for project in resume.projects %}
{% if (project.section or 'projects') != 'minor_projects' %}
\textbf{ {{- project.name | latex_escape -}} }{% if project.dates %} \hfill {{ (project.dates.start or '') | latex_escape -}}{% if project.dates.start and project.dates.end %} -- {% endif %}{{ (project.dates.end or '') | latex_escape -}}{% endif %}\\
{% if project.link %}{{- project.link | latex_escape -}}\\{% endif %}
{% if project.tech %}\textit{Tech}: {{ project.tech | join(', ') | latex_escape -}}\\{% endif %}
\begin{itemize}
{% for bullet in project.bullets %}
\item {{ bullet | latex_escape }}
{% endfor %}
\end{itemize}
{% endif %}
{% endfor %}
{% endif %}

{% if ns.minor_count > 0 %}
\section*{Minor Projects}
{% for project in resume.projects %}
{% if (project.section or 'projects') == 'minor_projects' %}
\textbf{ {{- project.name | latex_escape -}} }{% if project.dates %} \hfill {{ (project.dates.start or '') | latex_escape -}}{% if project.dates.start and project.dates.end %} -- {% endif %}{{ (project.dates.end or '') | latex_escape -}}{% endif %}\\
{% if project.tech %}\textit{Tech}: {{ project.tech | join(', ') | latex_escape -}}\\{% endif %}
\begin{itemize}
{% for bullet in project.bullets %}
\item {{ bullet | latex_escape }}
{% endfor %}
\end{itemize}
{% endif %}
{% endfor %}
{% endif %}

{% if resume.awards %}
\section*{Awards}
\begin{itemize}
{% for award in resume.awards %}
\item {{ award | latex_escape -}}
{% endfor %}
\end{itemize}
{% endif %}

\end{document}
